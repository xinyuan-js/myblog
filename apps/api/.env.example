APP_ENV=development
HTTP_ADDR=:8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# 生产环境仅填写实际反向代理的 IP 或 CIDR；留空时 Gin 不信任代理头。
TRUSTED_PROXIES=

# MySQL DSN。生产环境使用独立 blog_user，并确保 3306 不暴露到公网。
DATABASE_DSN=blog:change-me@tcp(127.0.0.1:3306)/blog?charset=utf8mb4&parseTime=true&loc=UTC&multiStatements=true&timeout=5s&readTimeout=10s&writeTimeout=10s
DATABASE_MAX_OPEN=10
DATABASE_MAX_IDLE=5
DATABASE_MAX_LIFETIME=30m

# 仅用于同步 Artalk 用户身份和管理员状态的最小权限数据库账号。
ARTALK_DATABASE_DSN=blog_artalk_bridge:change-me@tcp(127.0.0.1:3306)/artalk?charset=utf8mb4&parseTime=true&loc=UTC&timeout=5s&readTimeout=10s&writeTimeout=10s
ARTALK_INTERNAL_URL=http://127.0.0.1:23366

# GitHub OAuth 统一登录。所有 GitHub 用户可评论，ADMIN_GITHUB_ID 使用不可变数字 ID 授予管理权限。
APP_ORIGIN=http://localhost:5173
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_ID=
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback
OAUTH_STATE_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=blog_session
SESSION_COOKIE_SECURE=false
SESSION_TTL=168h
COMMENT_DAILY_LIMIT=20
COMMENT_DAY_UTC_OFFSET=8

# MinIO 仅通过容器内网访问；生产环境必须更换访问凭据。
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=blog-media
MINIO_USE_SSL=false

# 返回给前端的公开只读 URL 前缀，由 Nginx 转发到 blog-media Bucket。
MEDIA_PUBLIC_URL=/uploads
