# 生产部署模板：复制为 .env 后填写真实值，并执行 chmod 600 .env。
# .env 包含敏感信息，绝对不要提交到 Git。

# 站点与持久化
DATA_DIR=/mnt/cloud-disk/myblog
APP_ENV=production
APP_ORIGIN=https://blog.example.com
NGINX_SERVER_NAME=blog.example.com
HTTP_PORT=80
# 与宿主机其他 Docker/VPN 网段冲突时，改成另一个未使用的私有 /24 网段
BACKEND_SUBNET=172.28.0.0/24

# 可选：在 CI 构建后改为私有 Registry 的不可变摘要，并使用 compose up --no-build
# API_IMAGE=registry.example.com/myblog-api@sha256:...
# WEB_IMAGE=registry.example.com/myblog-web@sha256:...
# MYSQL_IMAGE=registry.example.com/myblog-mysql@sha256:...
# MINIO_IMAGE=registry.example.com/myblog-minio@sha256:...

# HTTPS 证书在宿主机上的实际文件路径
TLS_FULLCHAIN_FILE=/etc/letsencrypt/live/blog.example.com/fullchain.pem
TLS_PRIVATE_KEY_FILE=/etc/letsencrypt/live/blog.example.com/privkey.pem

# MySQL：四个密码必须分别生成，不要复用；三个应用密码仅使用字母和数字
MYSQL_ROOT_PASSWORD=replace-with-random-root-password
BLOG_DB_PASSWORD=replace-with-random-blog-password
ARTALK_DB_PASSWORD=replace-with-random-artalk-password
ARTALK_BRIDGE_DB_PASSWORD=replace-with-random-artalk-bridge-password

# MinIO：根账号只用于初始化；API 使用独立的 blog-media Bucket 凭据
MINIO_ROOT_USER=replace-with-random-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-at-least-32-random-root-characters
MINIO_ACCESS_KEY=myblog-api
MINIO_SECRET_KEY=replace-with-at-least-32-random-app-characters

# GitHub OAuth App
# Homepage URL: https://blog.example.com
# Callback URL: https://blog.example.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_ID=
OAUTH_STATE_SECRET=replace-with-at-least-32-random-characters

# 本站会话。生产环境必须使用 Secure Cookie；TTL 最大允许 720h（30 天）
SESSION_COOKIE_NAME=blog_session
SESSION_COOKIE_SECURE=true
SESSION_TTL=168h
COMMENT_DAILY_LIMIT=20
COMMENT_DAY_UTC_OFFSET=8

# Artalk 评论系统
ARTALK_SITE_NAME=MyBlog
ARTALK_APP_KEY=replace-with-at-least-32-random-characters
