# 复制为 .env。所有密码和密钥都必须重新生成，不要提交 .env。
DATA_DIR=./data
APP_ENV=production
APP_ORIGIN=https://blog.example.com
SESSION_COOKIE_SECURE=true
HTTP_PORT=80
TLS_FULLCHAIN_FILE=/etc/letsencrypt/live/blog.example.com/fullchain.pem
TLS_PRIVATE_KEY_FILE=/etc/letsencrypt/live/blog.example.com/privkey.pem

MYSQL_ROOT_PASSWORD=replace-with-random-root-password
BLOG_DB_PASSWORD=replace-with-random-blog-password
ARTALK_DB_PASSWORD=replace-with-random-artalk-password

MINIO_ACCESS_KEY=replace-with-random-minio-access
MINIO_SECRET_KEY=replace-with-at-least-32-random-characters

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_ID=
OAUTH_STATE_SECRET=replace-with-at-least-32-random-characters

ARTALK_SITE_NAME=MyBlog
ARTALK_APP_KEY=replace-with-at-least-32-random-characters
